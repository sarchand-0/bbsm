# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=bbsm
POSTGRES_PASSWORD=bbsmpassword
POSTGRES_DB=bbsm_ecommerce
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Backend ──────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000,http://frontend:3000
UPLOAD_DIR=/app/uploads

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# Points at Nginx which proxies /api/* → backend
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# ─── Google Maps (Store Locator) ──────────────────────────────────────────────
# Get your key from https://console.cloud.google.com → Maps JavaScript API
# Enable: Maps JavaScript API + Geocoding API (if you need address lookup)
# Restrict key to: HTTP referrers → localhost, your production domain
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
