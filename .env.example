# ── Database ──────────────────────────────────────────────────────────────────
# Production (RDS): set DATABASE_URL directly
DATABASE_URL=postgresql://bbsm:password@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/bbsm_ecommerce

# Local Docker Compose: comment out DATABASE_URL and use these instead
# POSTGRES_USER=bbsm
# POSTGRES_PASSWORD=bbsmpassword
# POSTGRES_DB=bbsm_ecommerce
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
# Production (Upstash): rediss:// with TLS
REDIS_URL=rediss://:<upstash-password>@<endpoint>.upstash.io:6379
# Local: redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── File Storage ──────────────────────────────────────────────────────────────
# Set USE_S3=true in production; false uses local disk
USE_S3=true
UPLOAD_DIR=/app/uploads
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=bbsm-uploads
AWS_S3_REGION=ap-south-1

# ── Frontend (Vercel env vars — set in Vercel dashboard) ──────────────────────
NEXT_PUBLIC_API_URL=https://your-backend.railway.app/api/v1

# ── Exchange rates ────────────────────────────────────────────────────────────
EXCHANGE_RATE_USD_NPR=135.0
EXCHANGE_RATE_INR_NPR=1.60
